rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId) && request.resource.data.uid == request.auth.uid;
      allow update: if isOwner(userId);
      allow delete: if false;
    }

    match /ideas/{ideaId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.authorName is string
        && request.resource.data.title is string
        && request.resource.data.description is string;
      allow update, delete: if false;
    }

    match /messages/{messageId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.ideaId is string
        && request.resource.data.userName is string
        && request.resource.data.text is string
        && exists(/databases/$(database)/documents/ideas/$(request.resource.data.ideaId))
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 400;
      allow update, delete: if false;
    }
  }
}
